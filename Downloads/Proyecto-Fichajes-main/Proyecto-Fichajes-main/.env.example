# Configuración del Sistema de Fichajes
# Copia este archivo a .env y ajusta los valores según tu configuración

# ========================================
# MONGODB - Base de Datos
# ========================================
MONGO_URI=mongodb://localhost:27017
DATABASE_NAME=CVKE
USUARIOS_COLLECTION=usuarios
FICHAJES_COLLECTION=fichajes

# ========================================
# TELEGRAM BOT
# ========================================
# Obtén tu token desde @BotFather en Telegram
TELEGRAM_TOKEN=

# ========================================
# BACKEND API (Opcional - FastAPI)
# ========================================
# Clave secreta para JWT (genera una aleatoria en producción)
SECRET_KEY=

# Algoritmo de encriptación
ALGORITHM=

# Tiempo de expiración del token en minutos (1440 = 24 horas)
ACCESS_TOKEN_EXPIRE_MINUTES=

# ========================================
# STREAMLIT (Opcional)
# ========================================
# Puerto del servidor Streamlit
STREAMLIT_SERVER_PORT=

# Habilitar modo desarrollo
STREAMLIT_SERVER_ENABLE_CORS=

# ========================================
# GENERAL
# ========================================
# Entorno de ejecución
ENVIRONMENT=

# Nivel de logs (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=
